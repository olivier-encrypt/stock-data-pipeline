					"referenceObjects": {
						"linkedServices": [],
						"datasets": []
					}
				},
				"linkedServiceName": {
					"referenceName": "AzureBatch_stocks",
					"type": "LinkedServiceReference"
				}
			},
			{
				"name": "run_transformations",
				"type": "SynapseNotebook",
