					"folderPath": "C:\\Users\\User\\OneDrive\\Documents\\database  system\\stock-market-pipeline\\ingestion",
					"referenceObjects": {
						"linkedServices": [],
						"datasets": []
					}
				},
				"linkedServiceName": {
					"referenceName": "AzureBatch_stocks",
					"type": "LinkedServiceReference"
				}
			},
